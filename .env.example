# ── Server ────────────────────────────────
PORT=3000

# ── ADB ───────────────────────────────────
# Path to adb binary (default: 'adb' assumes it's in PATH)
ADB_PATH=adb

# Specific device serial (leave blank for auto-detect)
# Find yours with: adb devices
# LDPlayer thường là: emulator-5554 hoặc 127.0.0.1:5555
ADB_DEVICE=

# Comma-separated tag filter — only show logs from these tags
# Leave blank to capture ALL tags
# Example: Unity,GameEngine,MyGame,il2cpp
ADB_TAGS=

# Minimum log level when no tag filter: V D I W E F
ADB_MIN_LEVEL=V

# ── Telegram ──────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Chat ID to send logs to
# For personal chat: message @userinfobot to get your ID
# For group: add bot to group, then check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# Set to 'false' to start with Telegram forwarding disabled
# (can toggle in the web UI at runtime)
TELEGRAM_ENABLED=true

# ── History ───────────────────────────────
# How many log lines to keep in memory for new browser connections
LOG_HISTORY_LIMIT=500
